{
  "name": "friendinerary",
  "version": "1.0.0",
  "private": true,
  "description": "FRIENDINERARY — Full-featured travel & itinerary planning platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @friendinerary/db generate",
    "db:migrate": "pnpm --filter @friendinerary/db migrate:dev",
    "db:push": "pnpm --filter @friendinerary/db db:push",
    "db:studio": "pnpm --filter @friendinerary/db studio",
    "db:seed": "pnpm --filter @friendinerary/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
